# ── EmailJS (formulario de contacto) ───────────────────────────────────
# 1. Crea una cuenta gratis en https://www.emailjs.com/
# 2. Crea un "Email Service" y una "Email Template".
# 3. Copia este archivo como ".env" y rellena los valores reales.
#
# IMPORTANTE: en Vite, las variables deben empezar por VITE_ para ser visibles.

VITE_EMAILJS_SERVICE_ID=tu_service_id
VITE_EMAILJS_TEMPLATE_ID=tu_template_id
VITE_EMAILJS_PUBLIC_KEY=tu_public_key
